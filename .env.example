DATABASE_URL=postgres://user:password@host:5432/psylex
NEXTAUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3000

# Optional browser Realtime. Prefer https:// so Vercel (HTTPS) can use wss://.
# If this is http:// while the app is https://, Supabase WS is skipped (SSE is used).
NEXT_PUBLIC_SUPABASE_URL=https://supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
